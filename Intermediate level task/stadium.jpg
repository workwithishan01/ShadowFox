						<div>
							<time itemprop="datePublished" datetime="2025-05-08T16:25:31+05:30"></time>
							<time itemprop="url" content="https://indianexpress.com/article/sports/cricket/dc-vs-pbks-ipl-2025-live-cricket-score-playing-11-punjab-kings-delhi-capitals-today-match-updates-9989423/#tie-lb-20250508162531"></time>
							<span itemscope="itemscope" itemprop="author" itemtype="https://schema.org/Person">
