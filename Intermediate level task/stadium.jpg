						<div>
							<time itemprop="datePublished" datetime="2025-05-08T20:16:54+05:30"></time>
							<time itemprop="url" content="https://indianexpress.com/article/sports/cricket/dc-vs-pbks-ipl-2025-live-cricket-score-playing-11-punjab-kings-delhi-capitals-today-match-updates-9989423/#tie-lb-20250508201654"></time>
							<span itemscope="itemscope" itemprop="author" itemtype="https://schema.org/Person">
								<meta content="amitkamath" itemprop="name">
							</span>
							<span itemtype="https://schema.org/ImageObject" itemscope="itemscope" itemprop="image">
								<meta itemprop="url" content="https://images.indianexpress.com/2025/05/PBKS-VS-DC-EVACUATION.jpg">
								<meta content="480" itemprop="width">
