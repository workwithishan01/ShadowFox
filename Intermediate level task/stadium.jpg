							<time itemprop="url" content="https://indianexpress.com/article/sports/cricket/dc-vs-pbks-ipl-2025-live-cricket-score-playing-11-punjab-kings-delhi-capitals-today-match-updates-9989423/#tie-lb-20250508212928"></time>
